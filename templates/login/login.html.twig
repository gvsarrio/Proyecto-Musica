{% extends 'base.html.twig' %}

{% block title %}Iniciar sesión — MusicHub{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block liquid_background %}
<div id="liquid-background"></div>
<script>
(function() {
    var bg = document.getElementById('liquid-background');
    var colors = ['rgba(12,255,220,0.7)', 'rgba(255,0,255,0.7)', 'rgba(66,0,255,0.7)', 'rgba(155,48,255,0.7)'];
    var blobs = [];

    for (var i = 0; i < 4; i++) {
        var blob = document.createElement('div');
        blob.classList.add('liquid-blob');
        var size = Math.random() * 250 + 200;
        blob.style.width  = size + 'px';
        blob.style.height = size + 'px';
        blob.style.left   = (Math.random() * 100) + '%';
        blob.style.top    = (Math.random() * 100) + '%';
        blob.style.background = colors[Math.floor(Math.random() * colors.length)];
        bg.appendChild(blob);
        blobs.push(blob);
    }

    function animateBlobs() {
        blobs.forEach(function(blob) {
            blob.style.left = (Math.random() * 100) + '%';
            blob.style.top  = (Math.random() * 100) + '%';
        });
    }

    setTimeout(animateBlobs, 100);
    setInterval(animateBlobs, 6000);

    document.addEventListener('mousemove', function(e) {
        var mx = e.clientX / window.innerWidth;
        var my = e.clientY / window.innerHeight;
        blobs.forEach(function(blob, i) {
            var dir = (i % 2 === 0) ? 1 : -1;
            var ox = (mx - 0.5) * 30 * dir;
            var oy = (my - 0.5) * 30 * dir;
            blob.style.transform = 'translate(calc(-50% + ' + ox + 'px), calc(-50% + ' + oy + 'px))';
        });
    });
})();
</script>
{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card-container">
        <div class="auth-card-header-accent-bar"></div>

        <form method="post">
            {% if error %}
                <div class="auth-error-alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div class="alert alert-success">
                    Estás conectado como {{ app.user.userIdentifier }}.
                    <a href="{{ logout_path() }}">Cerrar sesión</a>
                </div>
            {% endif %}

            <h1>Inicia sesión</h1>
            <hr class="auth-form-divider">

            <div class="mb-3">
                <label for="username" class="auth-form-label">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username"
                       class="auth-form-input" autocomplete="email" required autofocus
                       placeholder="usuario@ejemplo.com">
            </div>
            <div class="mb-3">
                <label for="password" class="auth-form-label">Contraseña</label>
                <input type="password" name="_password" id="password"
                       class="auth-form-input" autocomplete="current-password" required
                       placeholder="••••••••">
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection"
                       value="{{ csrf_token('authenticate') }}">
            </div>

            <button class="auth-submit-button" type="submit">Iniciar sesión</button>
        </form>

        <p class="auth-alternate-action-text">¿Sin cuenta? <a href="{{ path('app_register') }}">Regístrate aquí</a></p>
    </div>
</div>
{% endblock %}
