<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}MusicHub
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
		{% block stylesheets %}
			{# Bootswatch Vapor (incluye Bootstrap) #}
			<link
			href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.8/dist/vapor/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
			{# Estilos propios #}
			<link rel="stylesheet" href="{{ asset('css/style.css') }}">
		{% endblock %}
		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
		{% endblock %}
	</head>
	<body>
		{# Menú fuera del container para que ocupe todo el ancho #}
		<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
			<div class="container-fluid">
				<div class="collapse navbar-collapse" id="navbarNavAltMarkup">
					<div class="navbar-nav">
						<a href="{{ path('app_inicio') }}" {% if app.request.attributes.get('_route') == 'app_inicio' %} class="nav-link active" aria-current="page" {% else %} class="nav-link" {% endif %}>Inicio</a>
						{% if is_granted('IS_AUTHENTICATED') %}
							{% if not is_granted('ROLE_ADMIN') %}
								<a href="{{ path('app_musico') }}" {% if app.request.attributes.get('_route') == 'app_musico' %} class="nav-link active" aria-current="page" {% else %} class="nav-link" {% endif %}>Editar perfil</a>
							{% endif %}
							<a href="{{ path('app_logout') }}" class="nav-link">Salir</a>
						{% else %}
							<a href="{{ path('app_register') }}" {% if app.request.attributes.get('_route') == 'app_register' %} class="nav-link active" aria-current="page" {% else %} class="nav-link" {% endif %}>Registro</a>
							<a href="{{ path('app_login') }}" {% if app.request.attributes.get('_route') == 'app_login' %} class="nav-link active" aria-current="page" {% else %} class="nav-link" {% endif %}>Iniciar sesión</a>
						{% endif %}
						{% if is_granted('ROLE_ADMIN') %}
							<a href="{{ path('admin') }}" class="nav-link">Administrar usuarios</a>
						{% endif %}
					</div>
				</div>
			</div>
		</nav>

		{# Contenido de cada página #}
		<div class="container"> {% block body %}{% endblock %}
			</div>
		</body>
	</html>
