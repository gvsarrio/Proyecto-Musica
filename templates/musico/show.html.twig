{# templates/musico/show.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Perfil de {{ musico.nombre }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="mh-card p-0 shadow-lg" style="background: #1a1a2e; border-radius: 15px; overflow: hidden; border: 1px solid rgba(155, 48, 255, 0.2);">
                
                {# 1. HEADER CON LA FOTO #}
                <div class="text-center py-5" style="background: linear-gradient(180deg, rgba(155, 48, 255, 0.1) 0%, rgba(26, 26, 46, 1) 100%); border-bottom: 1px solid rgba(155, 48, 255, 0.1);">
                    <div class="position-relative d-inline-block">
                        {% if musico.imagenUrl %}
                            <img src="{{ asset('uploads/perfiles/' ~ musico.imagenUrl) }}" 
                                 alt="Foto de {{ musico.nombre }}" 
                                 class="rounded-circle shadow-lg" 
                                 style="width: 200px; height: 200px; object-fit: cover; border: 4px solid #9b30ff;">
                        {% else %}
                            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto" 
                                 style="width: 200px; height: 200px; background: #2a2a4a; border: 2px dashed #9b30ff;">
                                <span class="text-muted small">Sin foto de perfil</span>
                            </div>
                        {% endif %}
                    </div>
                    <h1 class="mt-3 text-white fw-bold" style="text-shadow: 0 0 15px rgba(155, 48, 255, 0.5);">{{ musico.nombre }}</h1>
                </div>

                {# 2. TABLA DE DATOS (Como el diseño de vuestra compañera) #}
                <div class="p-4">
                    <table class="table table-borderless text-white mb-0">
                        <tbody>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <th scope="row" class="py-3 text-primary" style="width: 30%;">Nombre artístico:</th>
                                <td class="py-3">{{ musico.nombre }}</td>
                            </tr>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <th scope="row" class="py-3 text-primary">Teléfono:</th>
                                <td class="py-3">{{ musico.telefono|default('No disponible') }}</td>
                            </tr>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <th scope="row" class="py-3 text-primary">Ubicación:</th>
                                <td class="py-3">{{ musico.ubicacion }}</td>
                            </tr>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <th scope="row" class="py-3 text-primary">Experiencia:</th>
                                <td class="py-3">{{ musico.anyosExperiencia }} años de trayectoria</td>
                            </tr>
                            <tr>
                                <th scope="row" class="py-3 text-primary">Biografía:</th>
                                <td class="py-3 text-muted" style="line-height: 1.6; font-style: italic;">
                                    "{{ musico.biografia }}"
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                {# 3. ACCIONES #}
                <div class="p-4 bg-dark bg-opacity-25 d-flex justify-content-center gap-3">
                    <a href="{{ path('app_musico_index') }}" class="btn btn-outline-light btn-sm px-4">
                        Ir al listado
                    </a>

                    {% if app.user and musico.usuario == app.user %}
                        <a href="{{ path('app_musico_edit', {'id': musico.id}) }}" class="btn btn-sm px-4 text-white" style="background: #9b30ff;">
                            Editar mi perfil
                        </a>
                        <form method="post" action="{{ path('app_musico_delete', {'id': musico.id}) }}" onsubmit="return confirm('¿Estás seguro de que quieres borrar tu perfil?');" style="display:inline-block">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ musico.id) }}">
                            <button class="btn btn-outline-danger btn-sm">Eliminar</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}