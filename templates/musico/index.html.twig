{% extends 'base.html.twig' %}

{% block title %}Musico{% endblock %}

{% block body %}
    <h1>Musico</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Nombre: </th>
                <th>Teléfono: </th>
                <th>Biografía: </th>
                <th>Ubicación: </th>
                <th>Años de experiencia: </th>
                <th>Imagen: </th>
                <th>Perfil creado:</th>
                <th>Perfil actualizado: </th>
                <th>Es una banda: </th>
                <th>Acciones: </th>
            </tr>
        </thead>
        <tbody>
        {% for musico in musicos %}
            <tr>
                <td>{{ musico.nombre }}</td>
                <td>{{ musico.telefono }}</td>
                <td>{{ musico.biografia }}</td>
                <td>{{ musico.ubicacion }}</td>
                <td>{{ musico.anyosExperiencia }}</td>
                <td>{{ musico.imagenUrl }}</td>
                <td>{{ musico.creadoEn ? musico.creadoEn|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ musico.actualizadoEn ? musico.actualizadoEn|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ musico.esBanda ? 'Yes' : 'No' }}</td>
                <td>
                    <a href="{{ path('app_musico_show', {'id': musico.id}) }}">show</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">No se han encontrado resultados</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}
