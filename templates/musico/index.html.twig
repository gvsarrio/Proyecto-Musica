{% extends 'base.html.twig' %}

{% block title %}Prueba API Musicos{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 2rem auto; max-width: 900px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code, pre { background: #F5F5F5; padding: 2px 6px; }
    .status { margin: 1rem 0; font-weight: 700; }
    .ok { color: #1f7a1f; }
    .error { color: #b42318; }
    .musicos-list { padding-left: 1.25rem; }
    .musicos-list li { margin-bottom: 0.75rem; }
    .muted { color: #666; }
</style>

<div class="example-wrapper">
    <h1>Prueba de la API de musicos</h1>

    <p>Esta vista hace una petición a <code>/api/musicos</code> para comprobar si la API responde.</p>

    <div id="api-status" class="status">Cargando...</div>

    <h2>Listado de musicos</h2>
    <ul id="api-response" class="musicos-list">
        <li>Esperando respuesta...</li>
    </ul>
</div>

<script>
    async function probarApiMusicos() {
        const statusElement = document.getElementById('api-status');
        const responseElement = document.getElementById('api-response');

        try {
            const response = await fetch('/api/musicos');
            const data = await response.json();

            if (!response.ok) {
                throw new Error('HTTP ' + response.status);
            }

            const items = data['hydra:member'] || data.member || data;

            statusElement.textContent = 'API funcionando correctamente';
            statusElement.className = 'status ok';

            if (!Array.isArray(items) || items.length === 0) {
                responseElement.innerHTML = '<li>No hay musicos para mostrar.</li>';
                return;
            }

            responseElement.innerHTML = items.map((musico) => {
                const nombre = musico.nombre ?? 'Sin nombre';
                const ubicacion = musico.ubicacion ?? 'Sin ubicacion';
                const experiencia = musico.anyosExperiencia ?? musico.anyos_experiencia ?? 'Sin dato';

                return `
                    <li>
                        <strong>${nombre}</strong><br>
                        <span class="muted">Ubicacion:</span> ${ubicacion}<br>
                        <span class="muted">Experiencia:</span> ${experiencia}
                    </li>
                `;
            }).join('');
        } catch (error) {
            statusElement.textContent = 'Error al conectar con la API';
            statusElement.className = 'status error';
            responseElement.innerHTML = `<li>${error.message}</li>`;
        }
    }

    probarApiMusicos();
</script>
{% endblock %}
