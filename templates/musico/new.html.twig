{% extends 'base.html.twig' %}

{% block title %}Nuevo perfil{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/perfil.css') }}">
    <style>
        /* Estilo rápido para que los checkboxes de instrumentos no salgan amontonados */
        .instrumentos-container {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(155, 48, 255, 0.3);
            border-radius: 8px;
            padding: 15px;
            max-height: 200px;
            overflow-y: auto;
        }
        .form-check {
            margin-bottom: 8px;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8">

                {# Mensajes de éxito #}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success mb-4">✓ {{ message }}</div>
                {% endfor %}

                <div class="mh-card p-4 shadow" style="background: #1a1a2e; border-radius: 15px; border-left: 5px solid #9b30ff;">
                    
                    {# Avatar / Icono decorativo #}
                    <div class="d-flex flex-column align-items-center mb-4">
                        <div class="mh-avatar mb-2" style="background: #2a2a4a; padding: 20px; border-radius: 50%;">
                            <svg width="45" height="45" viewbox="0 0 24 24" fill="none" stroke="#9b30ff" stroke-width="1.5">
                                <path d="M9 18V5l12-2v13"/>
                                <circle cx="6" cy="18" r="3"/>
                                <circle cx="18" cy="16" r="3"/>
                            </svg>
                        </div>
                    </div>

                    <h1 class="text-white mb-1">Nuevo perfil</h1>
                    <p class="text-muted mb-4">Completa tu información para empezar a conectar</p>
                    <hr style="border-color: rgba(155, 48, 255, 0.2);">

                    {# IMPORTANTE: enctype para permitir la subida de la foto #}
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                    
                    <div class="row g-3">
                        <div class="col-12">
                            {{ form_label(form.nombre, 'Nombre artístico ', {'label_attr': {'class': 'text-white'}}) }}
                            {{ form_widget(form.nombre, {'attr': {'class': 'form-control', 'placeholder': 'Ej: Sharknado'}}) }}
                            {{ form_errors(form.nombre) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_label(form.telefono, 'Teléfono de contacto', {'label_attr': {'class': 'text-white'}}) }}
                            {{ form_widget(form.telefono, {'attr': {'class': 'form-control', 'placeholder': 'Ej: 612 345 678'}}) }}
                            {{ form_errors(form.telefono) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_label(form.anyos_experiencia, 'Años de experiencia', {'label_attr': {'class': 'text-white'}}) }}
                            {{ form_widget(form.anyos_experiencia, {'attr': {'class': 'form-control', 'placeholder': 'Ej: 5'}}) }}
                            {{ form_errors(form.anyos_experiencia) }}
                        </div>

                        {# SECCIÓN DE INSTRUMENTOS (Checkboxes) #}
                        <div class="col-12">
                            {{ form_label(form.instrumentos, '¿Qué instrumentos tocas?', {'label_attr': {'class': 'text-white'}}) }}
                            <div class="instrumentos-container">
                                {{ form_widget(form.instrumentos) }}
                            </div>
                            <small class="text-muted">Selecciona todos los que apliquen.</small>
                            {{ form_errors(form.instrumentos) }}
                        </div>

                        <div class="col-12">
                            {{ form_label(form.ubicacion, 'Ubicación', {'label_attr': {'class': 'text-white'}}) }}
                            {{ form_widget(form.ubicacion, {'attr': {'class': 'form-control', 'placeholder': 'Ej: Murcia, España'}}) }}
                            {{ form_errors(form.ubicacion) }}
                        </div>

                        <div class="col-12">
                            {{ form_label(form.biografia, 'Tu biografía', {'label_attr': {'class': 'text-white'}}) }}
                            {{ form_widget(form.biografia, {'attr': {'class': 'form-control', 'rows': '4', 'placeholder': 'Cuéntanos sobre tu estilo, influencias...'}}) }}
                            {{ form_errors(form.biografia) }}
                        </div>

                        {# SUBIDA DE IMAGEN #}
                        <div class="col-12">
                            {{ form_label(form.imagen_url, 'Foto de perfil', {'label_attr': {'class': 'text-white'}}) }}
                            {{ form_widget(form.imagen_url, {'attr': {'class': 'form-control'}}) }}
                            <small class="text-muted">Formatos permitidos: JPG, PNG o WEBP (Máx. 2MB)</small>
                            {{ form_errors(form.imagen_url) }}
                        </div>
                    </div>

                    <div class="d-flex justify-content-center mt-5">
                        <button type="submit" class="btn btn-primary px-5 py-2" style="background: #9b30ff; border: none; font-weight: bold;">
                            CREAR MI PERFIL
                        </button>
                    </div>

                    {{ form_end(form) }}

                </div>
            </div>
        </div>
    </div>
{% endblock %}