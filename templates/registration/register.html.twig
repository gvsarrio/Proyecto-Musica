{% extends 'base.html.twig' %}

{% block title %}Crear cuenta — MusicHub{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block liquid_background %}
<div id="liquid-background"></div>
<script>
(function() {
    var bg = document.getElementById('liquid-background');
    var colors = ['rgba(12,255,220,0.7)', 'rgba(255,0,255,0.7)', 'rgba(66,0,255,0.7)', 'rgba(155,48,255,0.7)'];
    var blobs = [];

    for (var i = 0; i < 4; i++) {
        var blob = document.createElement('div');
        blob.classList.add('liquid-blob');
        var size = Math.random() * 250 + 200;
        blob.style.width  = size + 'px';
        blob.style.height = size + 'px';
        blob.style.left   = (Math.random() * 100) + '%';
        blob.style.top    = (Math.random() * 100) + '%';
        blob.style.background = colors[Math.floor(Math.random() * colors.length)];
        bg.appendChild(blob);
        blobs.push(blob);
    }

    function animateBlobs() {
        blobs.forEach(function(blob) {
            blob.style.left = (Math.random() * 100) + '%';
            blob.style.top  = (Math.random() * 100) + '%';
        });
    }

    setTimeout(animateBlobs, 100);
    setInterval(animateBlobs, 6000);

    document.addEventListener('mousemove', function(e) {
        var mx = e.clientX / window.innerWidth;
        var my = e.clientY / window.innerHeight;
        blobs.forEach(function(blob, i) {
            var dir = (i % 2 === 0) ? 1 : -1;
            var ox = (mx - 0.5) * 30 * dir;
            var oy = (my - 0.5) * 30 * dir;
            blob.style.transform = 'translate(calc(-50% + ' + ox + 'px), calc(-50% + ' + oy + 'px))';
        });
    });
})();
</script>
{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card-container">
        <div class="auth-card-header-accent-bar"></div>

        {% for flash_error in app.flashes('verify_email_error') %}
            <div class="auth-error-alert" role="alert">{{ flash_error }}</div>
        {% endfor %}

        <h1>Regístrate</h1>
        <hr class="auth-form-divider">

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm) }}
            {{ form_row(registrationForm.email, {
            label_attr: { class: 'auth-form-label' },
            attr: { placeholder: 'usuario@ejemplo.com' }
            }) }}
            {{ form_row(registrationForm.plainPassword, {
                label: 'Contraseña',
                label_attr: { class: 'auth-form-label' },
                attr: { placeholder: '••••••••' }
            }) }}
            {{ form_row(registrationForm.agreeTerms, {
                label: 'Aceptar términos y condiciones',
                label_attr: { class: 'auth-checkbox-label' }
            }) }}

            <button type="submit" class="auth-submit-button">Crear cuenta</button>
        {{ form_end(registrationForm) }}

        <p class="auth-alternate-action-text">¿Ya tienes cuenta? <a href="{{ path('app_login') }}">Inicia sesión</a></p>
    </div>
</div>
{% endblock %}
